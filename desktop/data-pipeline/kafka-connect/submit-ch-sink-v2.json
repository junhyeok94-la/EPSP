{
  "name": "clickhouse-sink-connector-v2",
  "config": {
    "connector.class": "com.clickhouse.kafka.connect.ClickHouseSinkConnector",
    "tasks.max": "1",
    "topics": "ecommerce.public.orders,ecommerce.public.products,ecommerce.public.dim_calendar,ecommerce.public.dim_campaign,ecommerce.public.dim_channel,ecommerce.public.dim_customer,ecommerce.public.dim_delivery_person,ecommerce.public.dim_fulfillment,ecommerce.public.dim_location,ecommerce.public.dim_payment,ecommerce.public.dim_product,ecommerce.public.dim_seller,ecommerce.public.fact_customer_rfm,ecommerce.public.fact_fulfillment_performance,ecommerce.public.fact_marketing_spend,ecommerce.public.fact_orders,ecommerce.public.fact_returns",
    "hostname": "clickhouse",
    "port": "8123",
    "database": "default",
    "username": "default",
    "password": "",
    "ssl": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "transforms": "route",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "ecommerce\\.public\\.(.*)",
    "transforms.route.replacement": "stg_$1"
  }
}
